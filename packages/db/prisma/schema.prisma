// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Video Game
// ============================================
model VideoGame {
  id        Int      @id
  slug      String   @unique
  name      String
  teams     Team[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Better Auth - User
// ============================================
model User {
  id              String         @id
  email           String         @unique
  emailVerified   Boolean        @default(false)
  name            String?
  image           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Custom fields
  coins           Int            @default(1000)
  favoriteTeamId  Int?
  favoriteTeam    Team?          @relation(fields: [favoriteTeamId], references: [id])
  
  // Admin fields (Better Auth admin plugin)
  role            String         @default("user") // user, admin
  banned          Boolean        @default(false)
  banReason       String?
  banExpires      DateTime?
  
  sessions        Session[]
  accounts        Account[]
  bets            Bet[]
  notifications   Notification[]
  createdBetOptions BetOption[]
  
  // Friend system
  sentFriendRequests     Friendship[]  @relation("SentFriendRequests")
  receivedFriendRequests Friendship[]  @relation("ReceivedFriendRequests")
  
  // Tracking & Favorites
  trackedTeams     TrackedTeam[]
  favoritePlayers  FavoritePlayer[]
  
  @@index([favoriteTeamId])
  @@index([role])
}

// ============================================
// Better Auth - Session
// ============================================
model Session {
  id              String    @id
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token           String    @unique
  expiresAt       DateTime
  ipAddress       String?
  userAgent       String?
  impersonatedBy  String?   // Admin user ID if impersonating
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId])
}

// ============================================
// Better Auth - Account (OAuth providers)
// ============================================
model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  accessTokenExpiresAt  DateTime?
  refreshToken          String?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([userId])
}

// ============================================
// Better Auth - Verification (email, etc.)
// ============================================
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================
// Friendship System
// ============================================
model Friendship {
  id          String           @id @default(cuid())
  senderId    String
  sender      User             @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User             @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ============================================
// Notification
// ============================================
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?          // Optional link to navigate to
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  
  @@index([userId])
  @@index([userId, read])
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  BET_WON
  BET_LOST
  SYSTEM
}

// ============================================
// Team
// ============================================
model Team {
  id              Int             @id
  slug            String          @unique
  name            String
  acronym         String?
  imageUrl        String?
  location        String?
  videogameId     Int?
  videogame       VideoGame?      @relation(fields: [videogameId], references: [id])
  players         Player[]
  matchOpponents  MatchOpponent[]
  favoriteOf      User[]
  trackedBy       TrackedTeam[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([videogameId])
}

// ============================================
// Tracked Teams (users can follow multiple teams)
// ============================================
model TrackedTeam {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
}

// ============================================
// Favorite Players
// ============================================
model FavoritePlayer {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playerId    Int
  playerSlug  String
  playerName  String
  playerImage String?
  teamName    String?
  createdAt   DateTime @default(now())
  
  @@unique([userId, playerId])
  @@index([userId])
}

// ============================================
// Player
// ============================================
model Player {
  id          Int      @id
  slug        String   @unique
  name        String   // In-game name (IGN)
  firstName   String?
  lastName    String?
  nationality String?
  imageUrl    String?
  role        String?
  teamId      Int?
  team        Team?    @relation(fields: [teamId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId])
  @@index([name])
}

// ============================================
// League
// ============================================
model League {
  id        Int      @id
  slug      String   @unique
  name      String
  imageUrl  String?
  series    Serie[]
  matches   Match[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Serie (Season / Edition)
// ============================================
model Serie {
  id          Int          @id
  slug        String       @unique
  name        String?
  fullName    String?
  beginAt     DateTime?
  endAt       DateTime?
  leagueId    Int?
  league      League?      @relation(fields: [leagueId], references: [id])
  tournaments Tournament[]
  matches     Match[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([leagueId])
}

// ============================================
// Tournament
// ============================================
model Tournament {
  id        Int      @id
  slug      String   @unique
  name      String
  tier      String?  // 's', 'a', 'b', 'c', 'd', 'unranked'
  beginAt   DateTime?
  endAt     DateTime?
  prizepool String?
  serieId   Int?
  serie     Serie?   @relation(fields: [serieId], references: [id])
  matches   Match[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serieId])
  @@index([tier])
}

// ============================================
// Match
// ============================================
model Match {
  id            Int             @id
  slug          String          @unique
  name          String
  status        String          // 'not_started', 'running', 'finished', 'canceled', 'postponed'
  scheduledAt   DateTime?
  beginAt       DateTime?
  endAt         DateTime?
  tier          String          // 'Tier 1', 'Tier 2', 'Other'
  numberOfGames Int?
  leagueId      Int?
  league        League?         @relation(fields: [leagueId], references: [id])
  serieId       Int?
  serie         Serie?          @relation(fields: [serieId], references: [id])
  tournamentId  Int?
  tournament    Tournament?     @relation(fields: [tournamentId], references: [id])
  opponents     MatchOpponent[]
  streams       MatchStream[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
  @@index([scheduledAt])
  @@index([leagueId])
  @@index([serieId])
  @@index([tournamentId])
  @@index([tier])
}

// ============================================
// Match Opponent (Junction table for Match-Team with score)
// ============================================
model MatchOpponent {
  id      Int   @id @default(autoincrement())
  matchId Int
  match   Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  teamId  Int
  team    Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  score   Int   @default(0)

  @@unique([matchId, teamId])
  @@index([matchId])
  @@index([teamId])
}

// ============================================
// Match Stream
// ============================================
model MatchStream {
  id       Int     @id @default(autoincrement())
  matchId  Int
  match    Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  language String
  rawUrl   String
  embedUrl String?
  official Boolean @default(false)
  main     Boolean @default(false)

  @@index([matchId])
}

// ============================================
// Bet (User betting on matches)
// ============================================
model Bet {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId       Int       // PandaScore match ID
  teamId        Int       // Team the user bet on
  amount        Int       // Amount of coins bet
  odds          Float     @default(2.0) // Default 2x odds
  status        BetStatus @default(PENDING)
  potentialWin  Int       // amount * odds
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@unique([userId, matchId]) // One bet per match per user
  @@index([userId])
  @@index([matchId])
  @@index([status])
}

enum BetStatus {
  PENDING   // Match not finished
  WON       // User's team won
  LOST      // User's team lost
  CANCELED  // Match was canceled/refunded
}

// ============================================
// Bet Options (Admin-created betting opportunities)
// ============================================
model BetOption {
  id            String    @id @default(cuid())
  matchId       Int       @unique // PandaScore match ID
  matchName     String    // For display purposes
  matchSlug     String?   // For linking to match page
  team1Id       Int
  team1Name     String
  team1Logo     String?
  team1Odds     Float     @default(2.0)
  team2Id       Int
  team2Name     String
  team2Logo     String?
  team2Odds     Float     @default(2.0)
  isActive      Boolean   @default(true)
  scheduledAt   DateTime? // Match scheduled time
  expiresAt     DateTime? // Auto-close betting before match
  createdById   String
  createdBy     User      @relation(fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive])
  @@index([scheduledAt])
  @@index([createdById])
}

