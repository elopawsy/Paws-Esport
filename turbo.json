{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": [
    "NODE_ENV",
    "API_PORT",
    "DATABASE_URL",
    "DIRECT_DATABASE_URL",
    "BETTER_AUTH_URL",
    "BETTER_AUTH_SECRET",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "PANDASCORE_API_KEY",
    "GRID_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "swagger": {
      "outputs": ["dist/swagger.json", "src/swagger.json"]
    },
    "sdk": {
      "outputs": ["src/index.ts", "src/**/*.ts"]
    },
    "clean": {
      "cache": false
    }
  }
}
