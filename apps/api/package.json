{
  "name": "@paws/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "ts-patch install -s",
    "clean": "rm -rf dist .turbo",
    "sdk": "node node_modules/@nestia/sdk/lib/executable/sdk.js sdk",
    "swagger": "node node_modules/@nestia/sdk/lib/executable/sdk.js swagger"
  },
  "dependencies": {
    "@nestia/core": "^4.6.0",
    "@nestia/fetcher": "^4.6.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@paws/convex": "workspace:*",
    "@paws/db": "workspace:*",
    "@prisma/client": "^7.2.0",
    "convex": "^1.16.0",
    "better-auth": "^1.4.7",
    "dotenv": "^17.2.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typia": "^7.5.1"
  },
  "devDependencies": {
    "@nestia/sdk": "^4.6.0",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@paws/tsconfig": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^20",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.3.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.7.2"
  }
}
